{
    "name": "shutdown-manager",
    "version": "1.0.0",
    "description": "Bilgisayar Kapatma Yöneticisi - Zamanlayıcı ve Uzaktan Kapatma",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder --win",
        "build:mac": "electron-builder --mac",
        "build:portable": "electron-builder --win portable"
    },
    "author": "ShutdownManager",
    "license": "MIT",
    "devDependencies": {
        "@electron/packager": "^19.0.5",
        "cross-env": "^10.1.0",
        "electron": "^40.6.1",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.shutdownmanager.app",
        "productName": "Shutdown Manager",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.js",
            "renderer/**/*",
            "tray-icon.png"
        ],
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "icon": "icon.icns"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "requestedExecutionLevel": "requireAdministrator"
        },
        "nsis": {
            "oneClick": true,
            "perMachine": true,
            "allowToChangeInstallationDirectory": false,
            "shortcutName": "Shutdown Manager"
        },
        "portable": {
            "artifactName": "ShutdownManager-Portable.exe"
        }
    },
    "dependencies": {
        "axios": "^1.13.5",
        "form-data": "^4.0.5",
        "node-telegram-bot-api": "^0.67.0",
        "screenshot-desktop": "^1.15.3"
    }
}